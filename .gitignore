node_modules/
dist/
build/
.next/
*.log

# Plugin and tool scratch dirs
.remember/
.code-review-graph/
.claude/
.worktrees/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Session logs (large, per-deployment)
sessions/
*.jsonl.gz

# Runtime data (config.db created by autopilot-server at boot)
data/

# Build artifacts (top-level dist/ from earlier covers all workspace dist/ as well)
*.tsbuildinfo

# Coverage
coverage/

# Next.js (top-level .next/ covers all workspace .next/ as well)
packages/*/out/
apps/*/out/

# Next.js auto-generated — rewritten on every build, varies between dev/prod runs
packages/*/next-env.d.ts

# Dev-session artifacts (Playwright snapshots and ad-hoc screenshots)
.playwright-mcp/
*.png

# Coastline data — downloaded by `npm run fetch --workspace @g5000/coastline`
packages/coastline/data/
