[Unit]
Description=G5000 forecast refresh (hits /api/forecast/refresh on the local autopilot)
After=g5000-autopilot.service network-online.target
# Intentionally NOT `Requires=g5000-autopilot.service` — we don't want
# systemd to auto-start the autopilot just to run a forecast refresh.
# The script self-guards with `systemctl is-active --quiet` and exits 0
# if the autopilot isn't running.

[Service]
Type=oneshot
User=greg
# Invoke via `bash` rather than directly, so the script doesn't need
# the executable bit. rsync over Tailscale strips +x bits from synced
# files, which used to cause this service to fail with EXEC=203 after
# every deploy. `bash` reads the file as plain text — permission bits
# on the script itself don't matter.
ExecStart=/usr/bin/bash /home/greg/autopilot/scripts/refresh-forecast.sh
StandardOutput=journal
StandardError=journal
